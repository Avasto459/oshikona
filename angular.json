{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "oshiqona-client": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "oshiqona-client/apps/client/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/oshiqona-client",
            "index": "oshiqona-client/apps/client/src/index.html",
            "main": "oshiqona-client/apps/client/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "oshiqona-client/apps/client/src/favicon.ico",
              "oshiqona-client/apps/client/src/assets"
            ],
            "styles": [
              "oshiqona-client/apps/client/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kb",
                  "maximumError": "20kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "oshiqona-client:build:production"
            },
            "development": {
              "browserTarget": "oshiqona-client:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "oshiqona-client:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "5de48d75-aad0-46e6-99c1-18a372f9719d"
  }
}
